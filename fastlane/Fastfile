# Fastlane configuration for Paperless Scanner
# https://docs.fastlane.tools

default_platform(:android)

# Cross-platform gradle wrapper detection
def gradle_wrapper
  if Gem.win_platform?
    "./gradlew.bat"
  else
    "./gradlew"
  end
end

platform :android do

  desc "Run unit tests"
  lane :test do
    gradle(
      task: "testDebugUnitTest",
      gradle_path: gradle_wrapper
    )
  end

  desc "Build debug APK"
  lane :build_debug do
    gradle(
      task: "assembleDebug",
      gradle_path: gradle_wrapper
    )
  end

  desc "Build release APK"
  lane :build_release do
    gradle(
      task: "assembleRelease",
      gradle_path: gradle_wrapper
    )
  end

  desc "Build release AAB (App Bundle)"
  lane :build_bundle do
    gradle(
      task: "bundleRelease",
      gradle_path: gradle_wrapper
    )
  end

  desc "Bump patch version"
  lane :bump_patch do
    gradle(
      task: "versionBumpPatch",
      gradle_path: gradle_wrapper
    )
  end

  desc "Bump minor version"
  lane :bump_minor do
    gradle(
      task: "versionBumpMinor",
      gradle_path: gradle_wrapper
    )
  end

  desc "Bump major version"
  lane :bump_major do
    gradle(
      task: "versionBumpMajor",
      gradle_path: gradle_wrapper
    )
  end

  desc "Deploy to internal testing track"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      # Skip ALL localized-content uploads (store listing + changelogs). The
      # Play API validates every configured listing language on upload and
      # rejects Gemini auto-translate languages it considers unsupported
      # (e.g. "ar"), failing the whole deploy — this blocked every internal
      # deploy from 2026-05-24 onward. Uploading only the AAB avoids the
      # translation validation entirely. Release notes are managed manually in
      # the Play Console until the unsupported auto-translate language is
      # removed there, after which skip_upload_changelogs can return to false.
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed"
    )
  end

  desc "Promote internal to production"
  lane :promote do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed"
    )
  end

  desc "Deploy to alpha track"
  lane :alpha do
    gradle(
      task: "bundleRelease",
      gradle_path: gradle_wrapper
    )
    upload_to_play_store(
      track: "alpha",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Deploy to beta track"
  lane :beta do
    gradle(
      task: "bundleRelease",
      gradle_path: gradle_wrapper
    )
    upload_to_play_store(
      track: "beta",
      aab: "app/build/outputs/bundle/release/app-release.aab"
    )
  end

  desc "Deploy to production"
  lane :production do
    gradle(
      task: "bundleRelease",
      gradle_path: gradle_wrapper
    )
    upload_to_play_store(
      track: "production",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft"
    )
  end

  desc "Upload metadata only (no APK/AAB)"
  lane :metadata do
    upload_to_play_store(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      sync_image_upload: true
    )
  end

  desc "Take screenshots (requires connected device)"
  lane :screenshots do
    capture_android_screenshots
  end

end
